<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="제품"
      jcr:description="정밀 측정 계측기 — CMM 시스템, 프로파일로미터 및 더 많은 제품 | Lumina Noventis"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B" model="hero-b2b" variant="centered"
              image="/content/dam/b2b-ue/images/2-people-pc-preview.jpg"
              preheader="정밀 계측 기기"
              header="모든 공차에 적합한 계측기"
              description="&lt;p&gt;5개의 제품군. 하나의 교정 표준. 의료용 임플란트의 표면 조도 검사부터 반도체 패키지의 인라인 치수 공차 검증까지, Lumina Noventis는 귀사의 공정에 맞는 계측기를 제공합니다.&lt;/p&gt;"
              cta1Text="데모 신청" cta1Link="/ko/contact"
              cta2Text="제품 카탈로그 다운로드" cta2Link="/ko/products/catalog"/>
      </section>

      <section_products jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header" model="section-header"
               eyebrow="당사 제품"
               heading="실패가 허용되지 않는 측정을 위해 설계된"
               subtitle="&lt;p&gt;좌표 측정 시스템부터 색채 분석 플랫폼까지, 모든 Lumina Noventis 계측기에는 추적 가능한 교정 인증서와 인더스트리 4.0 통합을 위한 완전한 연결성이 제공됩니다.&lt;/p&gt;"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards" filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;치수 측정&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;SpectraLink 시리즈&lt;/p&gt;&lt;h3&gt;CMM 시스템&lt;/h3&gt;&lt;p&gt;생산 속도에서 서브 마이크론 정확도 실현. 클린룸 없이 0.05 µm 이하의 측정 불확도.&lt;/p&gt;&lt;ul&gt;&lt;li&gt;≤ 0.05 µm 측정 불확도 (ISO 10360-2)&lt;/li&gt;&lt;li&gt;IP67 등급 · −10°C ~ +60°C 동작 범위&lt;/li&gt;&lt;li&gt;OPC-UA, EtherNet/IP, MQTT 연결성&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/ko/products/cmm-systems&quot;&gt;CMM 시스템 자세히 보기&lt;/a&gt;&lt;/p&gt;"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;표면 측정&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;DataPilot SP 시리즈&lt;/p&gt;&lt;h3&gt;광학 프로파일로미터&lt;/h3&gt;&lt;p&gt;나노미터 수준의 표면 세부 정보. 비접촉, 오염 없음. 웨이퍼, 광학, 임플란트용.&lt;/p&gt;&lt;ul&gt;&lt;li&gt;수직 분해능 0.1 nm (공초점 모드)&lt;/li&gt;&lt;li&gt;스캔 영역 0.3 mm × 0.3 mm ~ 100 mm × 100 mm&lt;/li&gt;&lt;li&gt;ISO 25178 · ASME B46.1 준수&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/ko/products/profilometers&quot;&gt;프로파일로미터 자세히 보기&lt;/a&gt;&lt;/p&gt;"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;색상 및 광 측정&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;ChromaSpec 시리즈&lt;/p&gt;&lt;h3&gt;분광광도계&lt;/h3&gt;&lt;p&gt;색상 품질 관리부터 광학 코팅 분석까지 — 하나의 플랫폼으로.&lt;/p&gt;&lt;ul&gt;&lt;li&gt;스펙트럼 범위 360 nm – 2500 nm (UV/VIS/NIR)&lt;/li&gt;&lt;li&gt;파장 정확도 ±0.3 nm&lt;/li&gt;&lt;li&gt;측정 기하학: d/8°, 45°/0°, 0°/45°&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/ko/products/spectrophotometers&quot;&gt;분광광도계 자세히 보기&lt;/a&gt;&lt;/p&gt;"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;기계 시험&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;NovForce 시리즈&lt;/p&gt;&lt;h3&gt;힘 및 토크 테스터&lt;/h3&gt;&lt;p&gt;단일 모듈형 플랫폼에서 인장, 압축, 박리, 굽힘 및 토크 시험. EN ISO 7500-1 정확도 클래스 0.5.&lt;/p&gt;&lt;ul&gt;&lt;li&gt;힘 범위: 0.1 mN – 100 kN (모델별 상이)&lt;/li&gt;&lt;li&gt;정확도 등급: EN ISO 7500-1 기준 0.5&lt;/li&gt;&lt;li&gt;FDA 21 CFR Part 11 · ISO 13485 대응&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/ko/products/force-torque-testers&quot;&gt;힘 및 토크 테스터 자세히 보기&lt;/a&gt;&lt;/p&gt;"/>
          <item5 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;데이터 및 통합&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;Lumina Suite&lt;/p&gt;&lt;h3&gt;소프트웨어 스위트&lt;/h3&gt;&lt;p&gt;현장의 모든 계측기를 하나의 대시보드로. SPC 대시보드, 자동 편차 경보, 감사 준비 보고서.&lt;/p&gt;&lt;ul&gt;&lt;li&gt;커넥터: OPC-UA, MQTT, REST API, SAP/Oracle ERP 모듈&lt;/li&gt;&lt;li&gt;FDA 21 CFR Part 11 · EU Annex 11 · ISO/IEC 17025 보고 템플릿&lt;/li&gt;&lt;li&gt;온프레미스, 프라이빗 클라우드 또는 Lumina Cloud SaaS&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/ko/products/software-suite&quot;&gt;소프트웨어 스위트 자세히 보기&lt;/a&gt;&lt;/p&gt;"/>
        </cards>
      </section_products>

      <section_callout jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B" model="hero-b2b" variant="cta"
              preheader="신제품 — 2026년 3월"
              header="SpectraLink 7000 시리즈: 공장 현장을 위한 CMM"
              description="&lt;p&gt;SpectraLink 7000은 20년간 인라인 계측 분야를 정의해 온 절충점을 없앴습니다. 0.05 µm 측정 불확도. 가혹한 생산 환경을 위한 IP67 등급. MES 직접 통합을 위한 OPC-UA 네이티브 — 예열 시간 없이 라인 속도로 작동하는 센서 하나에 담겼습니다.&lt;/p&gt;"
              cta1Text="데모 신청" cta1Link="/ko/contact"
              cta2Text="제품 출시 기사 읽기" cta2Link="/ko/news/spectralink-7000"
              stat1Value="0.05 µm" stat1Label="측정 불확도 (ISO 10360-2)"
              stat2Value="IP67" stat2Label="가혹한 생산 환경 대응 등급"
              stat3Value="40%" stat3Label="SpectraLink 5500 대비 노이즈 플로어 개선"/>
      </section_callout>

      <section_pillars jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header" model="section-header"
               eyebrow="40년 계측 혁신의 토대 위에 구축"
               heading="성능 사양은 시작에 불과합니다"
               subtitle="&lt;p&gt;계측기와 계측 시스템의 차이는 수치가 생성된 후 무슨 일이 일어나느냐에 있습니다. 모든 Lumina Noventis 제품은 정확도를 실행 가능하게 만드는 네 가지 핵심 역량을 중심으로 구축되어 있습니다.&lt;/p&gt;"
               ctaText="당사 기술에 대해 더 알아보기" ctaLink="/ko/about" style="dark-left"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards" filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="feature-tile" icon="check-shield"
                 text="&lt;h3&gt;OIML &amp;amp; ISO 소급성&lt;/h3&gt;&lt;p&gt;모든 교정 인증서는 국가 계측 기관에 소급됩니다. 예외 없음. 자체 인증 없음.&lt;/p&gt;"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="feature-tile" icon="hex-tolerance"
                 text="&lt;h3&gt;서브 마이크론 정확도&lt;/h3&gt;&lt;p&gt;당사 전체 치수 계측기 범위에서 0.1 µm 이하의 측정 불확도 — 독립 실험실 감사를 통해 검증됨.&lt;/p&gt;"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="feature-tile" icon="monitor"
                 text="&lt;h3&gt;IIoT / 인더스트리 4.0 대응&lt;/h3&gt;&lt;p&gt;OPC-UA, Profinet, REST API 출력은 당사가 출하하는 모든 계측기의 표준 기능입니다. 추가 옵션이 아닙니다.&lt;/p&gt;"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="feature-tile" icon="globe"
                 text="&lt;h3&gt;글로벌 서비스 네트워크&lt;/h3&gt;&lt;p&gt;30개국 42개 서비스 센터. 평균 응답 시간 4시간. 생산 핵심 설치에 대한 가동률 98.7% SLA.&lt;/p&gt;"/>
        </cards>
      </section_pillars>

      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B" model="hero-b2b" variant="cta"
              preheader="어디서 시작해야 할지 모르겠나요?"
              header="귀사의 측정 과제를 알려주세요"
              description="&lt;p&gt;당사 애플리케이션 엔지니어들은 120개 이상의 국가와 모든 주요 산업에 걸쳐 계측기와 공정을 매칭해 왔습니다. 공차, 환경 또는 규정 준수 요구 사항을 설명해 주시면 적합한 시스템을 추천해 드리겠습니다.&lt;/p&gt;"
              cta1Text="애플리케이션 엔지니어와 상담하기" cta1Link="/ko/contact"
              cta2Text="제품 카탈로그 다운로드" cta2Link="/ko/products/catalog"
              stat1Value="120+" stat1Label="서비스 국가"
              stat2Value="40+" stat2Label="년 계측 혁신"
              stat3Value="ISO 17025" stat3Label="인증 교정"/>
      </section_cta>

    </root>
  </jcr:content>
</jcr:root>
