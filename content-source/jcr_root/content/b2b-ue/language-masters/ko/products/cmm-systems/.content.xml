<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="CMM Systems"
      jcr:description="생산 라인 속도로 서브마이크론 좌표 계측 | SpectraLink 시리즈 | Lumina Noventis"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/2-people-pc-preview.jpg"
              preheader="치수 계측 · SpectraLink 시리즈"
              header="서브마이크론 정밀도. 생산 현장 대응."
              description="&lt;p&gt;측정 불확도 ≤ 0.05 µm의 CMM Systems — −10°C〜+60°C 생산 환경에 대응. 클린룸이 필요 없습니다.&lt;/p&gt;"
              cta1Text="데모 신청"
              cta1Link="/ko/contact"
              cta2Text="데이터시트 다운로드"
              cta2Link="/ko/products/cmm-systems/datasheet"
              stat1Value="≤ 0.05 µm"
              stat1Label="측정 불확도"
              stat2Value="IP67"
              stat2Label="생산 현장 대응"
              stat3Value="ISO 10360-2"
              stat3Label="정밀도 인증"/>
      </section>

      <section_intro jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="SpectraLink CMM 시스템"
               heading="부품이 실제로 제조되는 곳을 위한 좌표 계측"
               subtitle="&lt;p&gt;기존 CMM은 온도 제어된 측정실에 설치되어 있습니다——생산 현장과 분리되어 모든 품질 검사에 운반 시간과 병목 현상을 초래합니다. SpectraLink는 그 격차를 해소합니다. 생산 환경에서 직접 측정하여 라인 속도로 실험실 수준의 결과를 제공합니다.&lt;/p&gt;"/>
      </section_intro>

      <section_benefits jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="SpectraLink가 선택받는 이유"
               heading="생산 속도에 맞추는 정밀도"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="crosshair"
                 text="&lt;h3&gt;라인 속도로 측정&lt;/h3&gt;&lt;p&gt;기존 CMM은 검사 병목 현상을 만들어냅니다. SpectraLink는 몇 초 만에 서브마이크론 측정 결과를 제공합니다——생산 사이클을 늦추는 것이 아니라 그 속도에 맞춥니다.&lt;/p&gt;"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="check-shield"
                 text="&lt;h3&gt;클린룸 불필요. 정밀도도 타협 없음.&lt;/h3&gt;&lt;p&gt;IP67 실링과 −10°C〜+60°C 동작 온도 범위 덕분에 SpectraLink는 생산 현장에서 작동합니다. 부품이 있는 곳에서 측정할 수 있습니다——편리한 곳이 아닌.&lt;/p&gt;"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="globe"
                 text="&lt;h3&gt;네이티브 IIoT 연결&lt;/h3&gt;&lt;p&gt;OPC-UA, EtherNet/IP, MQTT 기본 탑재——추가 옵션이 아닙니다. SpectraLink는 MES, ERP, SPC 시스템에 직접 연결하여 실시간 품질 데이터를 실행으로 연결합니다.&lt;/p&gt;"/>
        </cards>
      </section_benefits>

      <section_specs jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               style="dark-left"
               eyebrow="기술 사양"
               heading="고객의 공차 요구 사항을 충족하는 규격"
               subtitle="&lt;p&gt;모든 SpectraLink 유닛은 추적 가능한 교정 인증서와 함께 출하됩니다. 측정 불확도는 규격대로 보장됩니다——추정치가 아닙니다.&lt;/p&gt;"
               ctaText="전체 데이터시트 다운로드"
               ctaLink="/ko/products/cmm-systems/datasheet"/>
        <content_fragment jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Content Fragment"
               model="content-fragment"
               reference="/content/dam/b2b-ue/product-specs/ko/cmm-systems"
               query="b2b-ue/product-spec-by-path"
               variableName="path"/>
      </section_specs>

      <section_applications jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="적용 분야"
               heading="정밀도가 가장 중요한 곳을 위해"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="crosshair"
                 text="&lt;h3&gt;항공우주&lt;/h3&gt;&lt;p&gt;터빈 블레이드 검사, 구조 부품 공차 관리, 기체 조립 중 인라인 검증——모두 생산 속도로 대응.&lt;/p&gt;"
                 ctastyle="link"
                 link="/ko/solutions/aerospace"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="monitor"
                 text="&lt;h3&gt;의료기기&lt;/h3&gt;&lt;p&gt;임플란트, 외과 기구, 진단 장비를 위한 FDA 21 CFR Part 11 준수 측정——감사 대비 보고서 기본 탑재.&lt;/p&gt;"
                 ctastyle="link"
                 link="/ko/solutions/medical"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="hex-tolerance"
                 text="&lt;h3&gt;자동차&lt;/h3&gt;&lt;p&gt;파워트레인 부품 검사, 차체 패널 공차 관리, 전기차 배터리 인클로저 검증을 위한 인라인 CMM——MES 연동.&lt;/p&gt;"
                 ctastyle="link"
                 link="/ko/solutions/automotive"/>
        </cards>
      </section_applications>

      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              variant="centered"
              preheader="시작하기"
              header="모든 도입은 계측 감사에서 시작합니다"
              description="&lt;p&gt;당사 계측 엔지니어가 고객의 공차 요구 사항에 최적화된 SpectraLink 구성을 제안합니다——그리고 인라인 측정이 병목 현상을 가장 효과적으로 해소할 수 있는 지점을 파악합니다.&lt;/p&gt;"
              cta1Text="상담 일정 예약"
              cta1Link="/ko/contact"
              cta2Text="데이터시트 다운로드"
              cta2Link="/ko/products/cmm-systems/datasheet"/>
      </section_cta>

    </root>
  </jcr:content>
</jcr:root>
