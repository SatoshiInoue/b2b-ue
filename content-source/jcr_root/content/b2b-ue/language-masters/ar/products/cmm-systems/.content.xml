<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="CMM Systems"
      jcr:description="قياس الإحداثيات دون المايكرون بسرعة خط الإنتاج | سلسلة SpectraLink | Lumina Noventis"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/2-people-pc-preview.jpg"
              preheader="قياس الأبعاد · سلسلة SpectraLink"
              header="دقة دون المايكرون. جاهز لبيئة الإنتاج."
              description="&lt;p&gt;أنظمة CMM بعدم يقين في القياس ≤ 0.05 µm — معتمدة لبيئات الإنتاج من −10°C إلى +60°C. بدون غرفة نظيفة.&lt;/p&gt;"
              cta1Text="طلب عرض توضيحي"
              cta1Link="/ar/contact"
              cta2Text="تنزيل صحيفة البيانات"
              cta2Link="/ar/products/cmm-systems/datasheet"
              stat1Value="≤ 0.05 µm"
              stat1Label="عدم اليقين في القياس"
              stat2Value="IP67"
              stat2Label="معتمد لبيئة الإنتاج"
              stat3Value="ISO 10360-2"
              stat3Label="دقة معتمدة"/>
      </section>

      <section_intro jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="نظام SpectraLink CMM"
               heading="قياس إحداثيات مصمم لحيث تُصنع القطع فعلاً"
               subtitle="&lt;p&gt;تعمل معظم أنظمة CMM في غرف قياس مكيّفة الهواء — بعيدة عن خط الإنتاج، مما يُضيف أوقات نقل وعوائق إلى كل عملية فحص جودة. SpectraLink يُزيل هذه الهوة. يقيس مباشرةً في بيئة الإنتاج، ويُقدم نتائج بجودة المختبر بسرعة خط الإنتاج.&lt;/p&gt;"/>
      </section_intro>

      <section_benefits jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="لماذا يختار المهندسون SpectraLink"
               heading="دقة تواكب إيقاع الإنتاج"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="crosshair"
                 text="&lt;h3&gt;القياس بسرعة الخط&lt;/h3&gt;&lt;p&gt;تُحدث أنظمة CMM التقليدية اختناقات في الفحص. يُقدم SpectraLink نتائج دون المايكرون في ثوانٍ — بسرعة كافية لمواكبة دورة إنتاجك، لا لإبطائها.&lt;/p&gt;"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="check-shield"
                 text="&lt;h3&gt;بدون غرفة نظيفة. بدون تنازلات.&lt;/h3&gt;&lt;p&gt;تعني درجة الحماية IP67 ونطاق درجة حرارة التشغيل من −10°C إلى +60°C أن SpectraLink يعمل في قاعة الإنتاج. قِس حيث توجد قطعك — لا حيث يناسبك.&lt;/p&gt;"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="globe"
                 text="&lt;h3&gt;اتصال IIoT أصلي&lt;/h3&gt;&lt;p&gt;OPC-UA وEtherNet/IP وMQTT مدمجة — وليست إضافية. يتصل SpectraLink مباشرةً بأنظمة MES وERP وSPC، ويُرسل بيانات الجودة في الوقت الفعلي.&lt;/p&gt;"/>
        </cards>
      </section_benefits>

      <section_specs jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               style="dark-left"
               eyebrow="المواصفات الفنية"
               heading="مُصنَّع وفق المعيار الذي تتطلبه تفاوتاتك"
               subtitle="&lt;p&gt;تُشحن كل وحدة SpectraLink مع شهادة معايرة قابلة للتتبع. عدم اليقين في القياس مضمون وفق المواصفات — وليس مقدَّراً.&lt;/p&gt;"
               ctaText="تنزيل صحيفة البيانات الكاملة"
               ctaLink="/ar/products/cmm-systems/datasheet"/>
        <content_fragment jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Content Fragment"
               model="content-fragment"
               reference="/content/dam/b2b-ue/product-specs/ar/cmm-systems"
               query="b2b-ue/product-spec-by-path"
               variableName="path"/>
      </section_specs>

      <section_applications jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="التطبيقات"
               heading="مُصمَّم للأماكن التي تكون فيها الدقة أكثر أهمية"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="crosshair"
                 text="&lt;h3&gt;الفضاء والطيران&lt;/h3&gt;&lt;p&gt;فحص ريش التوربينات، وإدارة تفاوتات المكونات الهيكلية، والتحقق المدمج أثناء تجميع هياكل الطائرات — وكل ذلك بمعدل الإنتاج.&lt;/p&gt;"
                 ctastyle="link"
                 link="/ar/solutions/aerospace"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="monitor"
                 text="&lt;h3&gt;الأجهزة الطبية&lt;/h3&gt;&lt;p&gt;قياس متوافق مع FDA 21 CFR Part 11 للزراعات والأدوات الجراحية ومعدات التشخيص — مع تقارير جاهزة للتدقيق مدمجة.&lt;/p&gt;"
                 ctastyle="link"
                 link="/ar/solutions/medical"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="hex-tolerance"
                 text="&lt;h3&gt;قطاع السيارات&lt;/h3&gt;&lt;p&gt;CMM مدمج في الخط لفحص مكونات ناقل الحركة، وإدارة تفاوتات لوحات الهيكل، والتحقق من مبيتات بطاريات السيارات الكهربائية — متكامل مع MES.&lt;/p&gt;"
                 ctastyle="link"
                 link="/ar/solutions/automotive"/>
        </cards>
      </section_applications>

      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              variant="centered"
              preheader="ابدأ الآن"
              header="كل عملية نشر تبدأ بتدقيق في القياس"
              description="&lt;p&gt;سيُطابق مهندسو المعايرة لدينا التكوين الصحيح لـ SpectraLink مع متطلبات تفاوتاتك — ويُحددون أين سيُزيل القياس المدمج أكبر عدد من الاختناقات.&lt;/p&gt;"
              cta1Text="جدولة مكالمة"
              cta1Link="/ar/contact"
              cta2Text="تنزيل صحيفة البيانات"
              cta2Link="/ar/products/cmm-systems/datasheet"/>
      </section_cta>

    </root>
  </jcr:content>
</jcr:root>
