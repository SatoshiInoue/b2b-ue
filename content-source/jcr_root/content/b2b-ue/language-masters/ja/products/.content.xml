<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="製品"
      jcr:description="精密計測機器 — CMMシステム、プロファイロメーターなど | Lumina Noventis"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              variant="centered"
              image="/content/dam/b2b-ue/images/2-people-pc-preview.jpg"
              preheader="精密計測機器"
              header="あらゆる公差に最適な計測器を"
              description="&lt;p&gt;5つの製品ファミリー。1つのキャリブレーション標準。医療用インプラントの表面粗さ検査から半導体パッケージのインライン寸法公差検証まで、Lumina Noventisはお客様のプロセスに最適な計測器を提供します。&lt;/p&gt;"
              cta1Text="デモをリクエストする"
              cta1Link="/ja/contact"
              cta2Text="製品カタログをダウンロード"
              cta2Link="/ja/products/catalog"/>
      </section>

      <section_products jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="製品ラインナップ"
               heading="失敗の許されない計測のために"
               subtitle="&lt;p&gt;座標測定システムからカラー解析プラットフォームまで、Lumina Noventisのすべての計測器にはトレーサブルなキャリブレーション証明書が付属し、インダストリー4.0統合のための完全なコネクティビティを備えています。&lt;/p&gt;"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;寸法測定&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;SpectraLinkシリーズ&lt;/p&gt;&lt;h3&gt;CMMシステム&lt;/h3&gt;&lt;p&gt;生産スピードでサブミクロン精度を実現。クリーンルーム不要で0.05 µm以下の測定不確かさ。&lt;/p&gt;&lt;ul&gt;&lt;li&gt;≤ 0.05 µm測定不確かさ（ISO 10360-2）&lt;/li&gt;&lt;li&gt;IP67対応・−10°C〜+60°C動作温度範囲&lt;/li&gt;&lt;li&gt;OPC-UA、EtherNet/IP、MQTT接続&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/ja/products/cmm-systems&quot;&gt;CMMシステムを詳しく見る&lt;/a&gt;&lt;/p&gt;"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;表面測定&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;DataPilot SPシリーズ&lt;/p&gt;&lt;h3&gt;光学式プロファイロメーター&lt;/h3&gt;&lt;p&gt;ナノメートル単位の表面詳細。非接触、無汚染。ウェハ、光学部品、インプラント向け。&lt;/p&gt;&lt;ul&gt;&lt;li&gt;垂直分解能0.1 nm（共焦点モード）&lt;/li&gt;&lt;li&gt;スキャンエリア0.3 mm × 0.3 mm〜100 mm × 100 mm&lt;/li&gt;&lt;li&gt;ISO 25178・ASME B46.1準拠&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/ja/products/profilometers&quot;&gt;プロファイロメーターを詳しく見る&lt;/a&gt;&lt;/p&gt;"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;色・光測定&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;ChromaSpecシリーズ&lt;/p&gt;&lt;h3&gt;分光光度計&lt;/h3&gt;&lt;p&gt;カラーQCから光学コーティング解析まで — 1つのプラットフォームで。球、45°/0°、双方向測定ジオメトリ。&lt;/p&gt;&lt;ul&gt;&lt;li&gt;スペクトル範囲360 nm – 2500 nm（UV/VIS/NIR）&lt;/li&gt;&lt;li&gt;波長精度±0.3 nm&lt;/li&gt;&lt;li&gt;ジオメトリ：d/8°、45°/0°、0°/45°&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/ja/products/spectrophotometers&quot;&gt;分光光度計を詳しく見る&lt;/a&gt;&lt;/p&gt;"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;機械試験&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;NovForceシリーズ&lt;/p&gt;&lt;h3&gt;力・トルクテスター&lt;/h3&gt;&lt;p&gt;引張、圧縮、剥離、曲げ、トルク試験に対応した単一モジュラープラットフォーム。EN ISO 7500-1精度クラス0.5。&lt;/p&gt;&lt;ul&gt;&lt;li&gt;力レンジ：0.1 mN – 100 kN（モデル依存）&lt;/li&gt;&lt;li&gt;精度クラス：EN ISO 7500-1準拠クラス0.5&lt;/li&gt;&lt;li&gt;FDA 21 CFR Part 11・ISO 13485対応&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/ja/products/force-torque-testers&quot;&gt;力・トルクテスターを詳しく見る&lt;/a&gt;&lt;/p&gt;"/>
          <item5 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;データ・統合&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;Lumina Suite&lt;/p&gt;&lt;h3&gt;ソフトウェアスイート&lt;/h3&gt;&lt;p&gt;フロア上のすべての計測器を1つのダッシュボードで管理。SPCダッシュボード、自動偏差アラート、監査対応レポート。&lt;/p&gt;&lt;ul&gt;&lt;li&gt;コネクタ：OPC-UA、MQTT、REST API、SAP/Oracle ERPモジュール&lt;/li&gt;&lt;li&gt;FDA 21 CFR Part 11・EU Annex 11・ISO/IEC 17025レポートテンプレート&lt;/li&gt;&lt;li&gt;オンプレミス、プライベートクラウド、またはLumina Cloud SaaS&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/ja/products/software-suite&quot;&gt;ソフトウェアスイートを詳しく見る&lt;/a&gt;&lt;/p&gt;"/>
        </cards>
      </section_products>

      <section_callout jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              variant="cta"
              preheader="新製品 — 2026年3月"
              header="SpectraLink 7000シリーズ: 工場フロアのためのCMM"
              description="&lt;p&gt;SpectraLink 7000は、インラインメトロロジーにおいて20年間にわたるトレードオフを解消します。0.05 µmの測定不確かさ。過酷な生産環境に対応したIP67定格。直接MES統合のためのOPC-UAネイティブ — すべてをウォームアップ時間なしにライン速度で動作するセンサーに実現。&lt;/p&gt;"
              cta1Text="デモをリクエストする"
              cta1Link="/ja/contact"
              cta2Text="製品ローンチ記事を読む"
              cta2Link="/ja/news/spectralink-7000"
              stat1Value="0.05 µm"
              stat1Label="測定不確かさ（ISO 10360-2）"
              stat2Value="IP67"
              stat2Label="過酷な生産環境対応定格"
              stat3Value="40%"
              stat3Label="SpectraLink 5500比ノイズフロア改善"/>
      </section_callout>

      <section_pillars jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="40年の計測技術革新に基づいて構築"
               heading="性能仕様は始まりに過ぎない"
               subtitle="&lt;p&gt;計測器と計測システムの違いは、数値が生成された後に何が起こるかにあります。Lumina Noventisのすべての製品は、精度を実行可能なものにする4つの機能を中心に構築されています。&lt;/p&gt;"
               ctaText="技術についてもっと詳しく"
               ctaLink="/ja/about"
               style="dark-left"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="check-shield"
                 text="&lt;h3&gt;OIML &amp;amp; ISO トレーサブル&lt;/h3&gt;&lt;p&gt;すべてのキャリブレーション証明書は国家計量機関にトレーサブルです。例外なし。自己証明なし。&lt;/p&gt;"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="hex-tolerance"
                 text="&lt;h3&gt;サブミクロン精度&lt;/h3&gt;&lt;p&gt;完全な寸法計測器レンジ全体で0.1 µm以下の測定不確かさ — 独立した試験所監査で検証済み。&lt;/p&gt;"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="monitor"
                 text="&lt;h3&gt;IIoT / インダストリー4.0対応&lt;/h3&gt;&lt;p&gt;OPC-UA、Profinet、REST API出力は、弊社が出荷するすべての計測器に標準搭載。オプションではありません。&lt;/p&gt;"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="globe"
                 text="&lt;h3&gt;グローバルサービスネットワーク&lt;/h3&gt;&lt;p&gt;30ヵ国42のサービスセンター。平均応答時間4時間。生産クリティカルインストールに対して稼働率98.7% SLA。&lt;/p&gt;"/>
        </cards>
      </section_pillars>

      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              variant="cta"
              preheader="どこから始めればよいかわからない方へ"
              header="計測上の課題をお聞かせください"
              description="&lt;p&gt;弊社のアプリケーションエンジニアは、120ヵ国以上、主要なすべての業界にわたって計測器とプロセスをマッチングしてきました。公差、環境、またはコンプライアンス要件をお聞かせいただければ、最適なシステムをご提案します。&lt;/p&gt;"
              cta1Text="アプリケーションエンジニアに相談する"
              cta1Link="/ja/contact"
              cta2Text="製品カタログをダウンロード"
              cta2Link="/ja/products/catalog"
              stat1Value="120+"
              stat1Label="ヵ国への提供実績"
              stat2Value="40+"
              stat2Label="年の計測技術革新"
              stat3Value="ISO 17025"
              stat3Label="認定キャリブレーション"/>
      </section_cta>

    </root>
  </jcr:content>
</jcr:root>
