<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="CMM Systems"
      jcr:description="生産ラインスピードでのサブミクロン座標計測 | SpectraLink シリーズ | Lumina Noventis"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/2-people-pc-preview.jpg"
              preheader="寸法計測 · SpectraLink シリーズ"
              header="サブミクロン精度。工場フロア対応。"
              description="&lt;p&gt;測定不確かさ ≤ 0.05 µm の CMM Systems — −10°C〜+60°C の生産環境に対応。クリーンルームは不要です。&lt;/p&gt;"
              cta1Text="デモをリクエスト"
              cta1Link="/ja/contact"
              cta2Text="データシートをダウンロード"
              cta2Link="/ja/products/cmm-systems/datasheet"
              stat1Value="≤ 0.05 µm"
              stat1Label="測定不確かさ"
              stat2Value="IP67"
              stat2Label="工場フロア対応"
              stat3Value="ISO 10360-2"
              stat3Label="精度認証"/>
      </section>

      <section_intro jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="SpectraLink CMM システム"
               heading="部品が実際に製造される場所のための座標計測"
               subtitle="&lt;p&gt;従来の CMM は温度管理された測定室に設置されています——工場フロアから切り離されているため、すべての品質チェックに輸送時間とボトルネックが生じます。SpectraLink はそのギャップを解消します。生産環境で直接計測を行い、ラインスピードでラボグレードの結果を提供します。&lt;/p&gt;"/>
      </section_intro>

      <section_benefits jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="SpectraLink が選ばれる理由"
               heading="生産ペースに追いつく精度"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="crosshair"
                 text="&lt;h3&gt;ラインスピードでの計測&lt;/h3&gt;&lt;p&gt;従来の CMM は検査のボトルネックを生み出します。SpectraLink は数秒でサブミクロンの計測結果を提供——生産サイクルを遅らせるのではなく、そのペースに追いつきます。&lt;/p&gt;"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="check-shield"
                 text="&lt;h3&gt;クリーンルーム不要。精度も妥協なし。&lt;/h3&gt;&lt;p&gt;IP67 シーリングと −10°C〜+60°C の動作温度範囲により、SpectraLink は工場フロアで稼働します。部品がある場所で計測できます——都合のいい場所ではなく。&lt;/p&gt;"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="globe"
                 text="&lt;h3&gt;ネイティブ IIoT 接続&lt;/h3&gt;&lt;p&gt;OPC-UA、EtherNet/IP、MQTT を標準搭載——後付けではありません。SpectraLink は MES、ERP、SPC システムに直接接続し、リアルタイムの品質データをアクションにつなげます。&lt;/p&gt;"/>
        </cards>
      </section_benefits>

      <section_specs jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               style="dark-left"
               eyebrow="技術仕様"
               heading="お客様の公差要件を満たす規格に準拠"
               subtitle="&lt;p&gt;すべての SpectraLink ユニットはトレーサブルな校正証明書とともに出荷されます。測定不確かさは仕様どおりに保証されています——推定値ではありません。&lt;/p&gt;"
               ctaText="詳細データシートをダウンロード"
               ctaLink="/ja/products/cmm-systems/datasheet"/>
        <content_fragment jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Content Fragment"
               model="content-fragment"
               reference="/content/dam/b2b-ue/product-specs/ja/cmm-systems"
               query="b2b-ue/product-spec-by-path"
               variableName="path"/>
      </section_specs>

      <section_applications jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="適用分野"
               heading="精度が最も求められる場所のために"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="crosshair"
                 text="&lt;h3&gt;航空宇宙&lt;/h3&gt;&lt;p&gt;タービンブレード検査、構造部品の公差管理、機体組み立て中のインプロセス検証——すべて生産レートで対応。&lt;/p&gt;"
                 ctastyle="link"
                 link="/ja/solutions/aerospace"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="monitor"
                 text="&lt;h3&gt;医療機器&lt;/h3&gt;&lt;p&gt;インプラント、外科器具、診断機器向けの FDA 21 CFR Part 11 準拠計測——監査対応レポートを標準搭載。&lt;/p&gt;"
                 ctastyle="link"
                 link="/ja/solutions/medical"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="hex-tolerance"
                 text="&lt;h3&gt;自動車&lt;/h3&gt;&lt;p&gt;パワートレイン部品検査、ボディパネルの公差管理、EV バッテリーエンクロージャー検証向けインライン CMM——MES との統合対応。&lt;/p&gt;"
                 ctastyle="link"
                 link="/ja/solutions/automotive"/>
        </cards>
      </section_applications>

      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              variant="centered"
              preheader="はじめに"
              header="すべての導入は計測監査から始まります"
              description="&lt;p&gt;当社の計測エンジニアが、お客様の公差要件に最適な SpectraLink 構成をご提案します——そして、インライン計測がボトルネックを最も解消できる箇所を特定します。&lt;/p&gt;"
              cta1Text="お打ち合わせのスケジュールを設定"
              cta1Link="/ja/contact"
              cta2Text="データシートをダウンロード"
              cta2Link="/ja/products/cmm-systems/datasheet"/>
      </section_cta>

    </root>
  </jcr:content>
</jcr:root>
