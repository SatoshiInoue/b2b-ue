<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="产品"
      jcr:description="精密测量仪器——CMM系统、轮廓仪及更多 | Lumina Noventis"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B" model="hero-b2b" variant="centered"
              image="/content/dam/b2b-ue/images/2-people-pc-preview.jpg"
              preheader="精密仪器"
              header="每种公差都有最合适的仪器"
              description="&lt;p&gt;五个产品系列。一个校准标准。无论您是在鉴定医疗植入物的表面粗糙度，还是验证半导体封装的在线尺寸公差，Lumina Noventis都能为您的工艺打造合适的仪器。&lt;/p&gt;"
              cta1Text="申请演示" cta1Link="/zh/contact"
              cta2Text="下载产品目录" cta2Link="/zh/products/catalog"/>
      </section>

      <section_products jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header" model="section-header"
               eyebrow="我们的产品"
               heading="专为不容失败的测量而生"
               subtitle="&lt;p&gt;从坐标测量系统到色彩分析平台，每台 Lumina Noventis 仪器均附带可追溯的校准证书，并具备完整的工业4.0集成连接能力。&lt;/p&gt;"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards" filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;尺寸测量&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;SpectraLink系列&lt;/p&gt;&lt;h3&gt;CMM系统&lt;/h3&gt;&lt;p&gt;以生产速度实现亚微米精度。无需洁净室，测量不确定度低于0.05 µm。&lt;/p&gt;&lt;ul&gt;&lt;li&gt;≤ 0.05 µm测量不确定度（ISO 10360-2）&lt;/li&gt;&lt;li&gt;IP67认证・−10°C至+60°C工作范围&lt;/li&gt;&lt;li&gt;OPC-UA、EtherNet/IP、MQTT连接&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/zh/products/cmm-systems&quot;&gt;探索CMM系统&lt;/a&gt;&lt;/p&gt;"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;表面测量&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;DataPilot SP系列&lt;/p&gt;&lt;h3&gt;光学轮廓仪&lt;/h3&gt;&lt;p&gt;纳米级表面细节。非接触，零污染。适用于晶圆、光学元件和骨科植入物。&lt;/p&gt;&lt;ul&gt;&lt;li&gt;垂直分辨率0.1 nm（共焦模式）&lt;/li&gt;&lt;li&gt;扫描范围0.3 mm × 0.3 mm至100 mm × 100 mm&lt;/li&gt;&lt;li&gt;ISO 25178・ASME B46.1符合&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/zh/products/profilometers&quot;&gt;探索轮廓仪&lt;/a&gt;&lt;/p&gt;"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;颜色与光测量&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;ChromaSpec系列&lt;/p&gt;&lt;h3&gt;分光光度计&lt;/h3&gt;&lt;p&gt;从颜色质量控制到光学镀膜分析——一个平台全覆盖。&lt;/p&gt;&lt;ul&gt;&lt;li&gt;光谱范围360 nm – 2500 nm（UV/VIS/NIR）&lt;/li&gt;&lt;li&gt;波长精度±0.3 nm&lt;/li&gt;&lt;li&gt;测量几何：d/8°、45°/0°、0°/45°&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/zh/products/spectrophotometers&quot;&gt;探索分光光度计&lt;/a&gt;&lt;/p&gt;"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;机械测试&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;NovForce系列&lt;/p&gt;&lt;h3&gt;力与扭矩测试仪&lt;/h3&gt;&lt;p&gt;单一模块化平台处理拉伸、压缩、剥离、弯曲和扭矩测试。EN ISO 7500-1精度0.5级。&lt;/p&gt;&lt;ul&gt;&lt;li&gt;力范围：0.1 mN – 100 kN（取决于型号）&lt;/li&gt;&lt;li&gt;精度等级：EN ISO 7500-1规定的0.5级&lt;/li&gt;&lt;li&gt;FDA 21 CFR Part 11・ISO 13485就绪&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/zh/products/force-torque-testers&quot;&gt;探索力与扭矩测试仪&lt;/a&gt;&lt;/p&gt;"/>
          <item5 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="product-card"
                 text="&lt;p class=&quot;badge&quot;&gt;数据与集成&lt;/p&gt;&lt;p class=&quot;product-line&quot;&gt;Lumina Suite&lt;/p&gt;&lt;h3&gt;软件套件&lt;/h3&gt;&lt;p&gt;一个仪表板管理车间所有仪器。可配置的SPC仪表板、自动偏差报警和一键审计就绪报告。&lt;/p&gt;&lt;ul&gt;&lt;li&gt;连接器：OPC-UA、MQTT、REST API、SAP/Oracle ERP模块&lt;/li&gt;&lt;li&gt;FDA 21 CFR Part 11・EU Annex 11・ISO/IEC 17025报告模板&lt;/li&gt;&lt;li&gt;本地部署、私有云或Lumina Cloud SaaS&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;a href=&quot;/zh/products/software-suite&quot;&gt;探索软件套件&lt;/a&gt;&lt;/p&gt;"/>
        </cards>
      </section_products>

      <section_callout jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B" model="hero-b2b" variant="cta"
              preheader="新品 — 2026年3月"
              header="SpectraLink 7000系列：为工厂车间而生的CMM"
              description="&lt;p&gt;SpectraLink 7000消除了困扰在线测量领域二十年的折中难题。0.05 µm测量不确定度。IP67防护等级，适用于恶劣生产环境。原生OPC-UA，支持MES直接集成——所有这些集于一个无需预热即可以产线速度运行的传感器之中。&lt;/p&gt;"
              cta1Text="申请演示" cta1Link="/zh/contact"
              cta2Text="阅读产品发布文章" cta2Link="/zh/news/spectralink-7000"
              stat1Value="0.05 µm" stat1Label="测量不确定度（ISO 10360-2）"
              stat2Value="IP67" stat2Label="适用于恶劣生产环境的防护等级"
              stat3Value="40%" stat3Label="相比 SpectraLink 5500 的噪声底线改善"/>
      </section_callout>

      <section_pillars jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header" model="section-header"
               eyebrow="建立在40年测量技术创新之上"
               heading="性能规格只是起点"
               subtitle="&lt;p&gt;测量仪器与测量系统的区别，在于数字生成之后发生的一切。每款 Lumina Noventis 产品都围绕四项核心能力构建，让精度真正付诸行动。&lt;/p&gt;"
               ctaText="了解我们的技术" ctaLink="/zh/about" style="dark-left"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards" filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="feature-tile" icon="check-shield"
                 text="&lt;h3&gt;OIML &amp;amp; ISO 溯源&lt;/h3&gt;&lt;p&gt;每份校准证书均可追溯至国家计量机构。无一例外。无自我认证。&lt;/p&gt;"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="feature-tile" icon="hex-tolerance"
                 text="&lt;h3&gt;亚微米精度&lt;/h3&gt;&lt;p&gt;在我们完整的尺寸仪器系列中，测量不确定度低于0.1 µm——经独立实验室审核验证。&lt;/p&gt;"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="feature-tile" icon="monitor"
                 text="&lt;h3&gt;IIoT / 工业4.0就绪&lt;/h3&gt;&lt;p&gt;OPC-UA、Profinet和REST API输出是我们出厂每台仪器的标准配置。非选配。非固件升级。&lt;/p&gt;"/>
          <item4 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card" model="card" cardstyle="feature-tile" icon="globe"
                 text="&lt;h3&gt;全球服务网络&lt;/h3&gt;&lt;p&gt;30个国家42个服务中心。平均响应时间4小时。关键生产安装系统可用率98.7% SLA。&lt;/p&gt;"/>
        </cards>
      </section_pillars>

      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B" model="hero-b2b" variant="cta"
              preheader="不确定从哪里开始？"
              header="告诉我们您的测量挑战"
              description="&lt;p&gt;我们的应用工程师已在120多个国家和各主要行业中为仪器与工艺找到了最佳匹配。请描述您的公差、环境或合规要求——我们将为您推荐最合适的系统。&lt;/p&gt;"
              cta1Text="与应用工程师交流" cta1Link="/zh/contact"
              cta2Text="下载产品目录" cta2Link="/zh/products/catalog"
              stat1Value="120+" stat1Label="服务国家"
              stat2Value="40+" stat2Label="年测量技术创新"
              stat3Value="ISO 17025" stat3Label="认证校准"/>
      </section_cta>

    </root>
  </jcr:content>
</jcr:root>
