<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
  <jcr:content
      cq:template="/libs/core/franklin/templates/page"
      jcr:primaryType="cq:PageContent"
      jcr:title="CMM Systems"
      jcr:description="以生产线速度实现亚微米坐标测量 | SpectraLink 系列 | Lumina Noventis"
      sling:resourceType="core/franklin/components/page/v1/page">
    <root jcr:primaryType="nt:unstructured"
          sling:resourceType="core/franklin/components/root/v1/root">

      <section jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              image="/content/dam/b2b-ue/images/2-people-pc-preview.jpg"
              preheader="尺寸测量 · SpectraLink 系列"
              header="亚微米精度。工厂车间就绪。"
              description="&lt;p&gt;测量不确定度 ≤ 0.05 µm 的 CMM Systems——适用于 −10°C〜+60°C 生产环境。无需洁净室。&lt;/p&gt;"
              cta1Text="申请演示"
              cta1Link="/zh/contact"
              cta2Text="下载数据表"
              cta2Link="/zh/products/cmm-systems/datasheet"
              stat1Value="≤ 0.05 µm"
              stat1Label="测量不确定度"
              stat2Value="IP67"
              stat2Label="工厂车间认证"
              stat3Value="ISO 10360-2"
              stat3Label="精度认证"/>
      </section>

      <section_intro jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="SpectraLink CMM 系统"
               heading="专为零件实际制造场所设计的坐标测量"
               subtitle="&lt;p&gt;传统 CMM 安置在温控测量室中——远离生产车间，每次质检都增加运输时间和瓶颈。SpectraLink 消除了这一差距。直接在生产环境中测量，以生产线速度提供实验室级的结果。&lt;/p&gt;"/>
      </section_intro>

      <section_benefits jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="为何选择 SpectraLink"
               heading="跟上生产节奏的精度"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="crosshair"
                 text="&lt;h3&gt;以线速测量&lt;/h3&gt;&lt;p&gt;传统 CMM 造成检测瓶颈。SpectraLink 在数秒内提供亚微米级测量结果——足以跟上您的生产周期，而不是拖慢它。&lt;/p&gt;"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="check-shield"
                 text="&lt;h3&gt;无需洁净室，精度无妥协。&lt;/h3&gt;&lt;p&gt;IP67 防护等级和 −10°C〜+60°C 的工作温度范围意味着 SpectraLink 在工厂车间运行。在零件所在的地方测量——而不是在方便的地方。&lt;/p&gt;"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="feature-tile"
                 icon="globe"
                 text="&lt;h3&gt;原生 IIoT 连接&lt;/h3&gt;&lt;p&gt;OPC-UA、EtherNet/IP 和 MQTT 内置——而非附加选项。SpectraLink 直接连接您的 MES、ERP 和 SPC 系统，将实时质量数据传输到能够采取行动的系统。&lt;/p&gt;"/>
        </cards>
      </section_benefits>

      <section_specs jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section"
               style="feature-split">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               style="dark-left"
               eyebrow="技术规格"
               heading="符合您公差要求的标准"
               subtitle="&lt;p&gt;每台 SpectraLink 出厂时均附有可溯源的校准证书。测量不确定度按规格保证——而非估算。&lt;/p&gt;"
               ctaText="下载完整数据表"
               ctaLink="/zh/products/cmm-systems/datasheet"/>
        <content_fragment jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Content Fragment"
               model="content-fragment"
               reference="/content/dam/b2b-ue/product-specs/zh/cmm-systems"
               query="b2b-ue/product-spec-by-path"
               variableName="path"/>
      </section_specs>

      <section_applications jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <section_header jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Section Header"
               model="section-header"
               eyebrow="应用领域"
               heading="专为精度要求最高的场所打造"/>
        <cards jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/block/v1/block"
               name="Cards"
               filter="cards">
          <item1 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="crosshair"
                 text="&lt;h3&gt;航空航天&lt;/h3&gt;&lt;p&gt;涡轮叶片检测、结构部件公差管理及机体装配过程中的在线验证——全部以生产速率完成。&lt;/p&gt;"
                 ctastyle="link"
                 link="/zh/solutions/aerospace"/>
          <item2 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="monitor"
                 text="&lt;h3&gt;医疗器械&lt;/h3&gt;&lt;p&gt;面向植入物、外科器械和诊断设备的 FDA 21 CFR Part 11 合规测量——内置审计就绪报告。&lt;/p&gt;"
                 ctastyle="link"
                 link="/zh/solutions/medical"/>
          <item3 jcr:primaryType="nt:unstructured"
                 sling:resourceType="core/franklin/components/block/v1/block/item"
                 name="Card"
                 model="card"
                 cardstyle="solution-tile"
                 icon="hex-tolerance"
                 text="&lt;h3&gt;汽车&lt;/h3&gt;&lt;p&gt;用于动力总成部件检测、车身面板公差管理和电动汽车电池外壳验证的在线 CMM——与 MES 集成。&lt;/p&gt;"
                 ctastyle="link"
                 link="/zh/solutions/automotive"/>
        </cards>
      </section_applications>

      <section_cta jcr:primaryType="nt:unstructured"
               sling:resourceType="core/franklin/components/section/v1/section">
        <hero_b2b jcr:primaryType="nt:unstructured"
              sling:resourceType="core/franklin/components/block/v1/block"
              name="Hero B2B"
              model="hero-b2b"
              variant="centered"
              preheader="开始使用"
              header="每次部署都从测量审计开始"
              description="&lt;p&gt;我们的计量工程师将为您的公差要求匹配正确的 SpectraLink 配置——并确定内联测量能最大程度消除瓶颈的环节。&lt;/p&gt;"
              cta1Text="安排通话"
              cta1Link="/zh/contact"
              cta2Text="下载数据表"
              cta2Link="/zh/products/cmm-systems/datasheet"/>
      </section_cta>

    </root>
  </jcr:content>
</jcr:root>
